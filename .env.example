# ─────────────────────────────────────────────────────────────────────────────
#  SmartVenue AI — Root Environment Variables for Docker Compose
#  Copy: cp .env.example .env   then fill in values
#  These variables are consumed by docker-compose.yml
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=5000

# REQUIRED: Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret_here
JWT_EXPIRY=7d

FRONTEND_URL=http://localhost:3000

# Optional: connect to a real MongoDB instead of in-memory.
# MongoDB Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/smartvenue
# Docker Mongo:   mongodb://mongo:27017/smartvenue
# MONGO_URI=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# Baked into the Next.js JS bundle at build time.
# Must match the actual backend host (container name or public URL).
NEXT_PUBLIC_API_URL=http://localhost:5000

# Override if Socket.IO lives on a different host:
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
